# Copy to .env.local and fill in real values. Never commit .env.local.
# Variable names only — see VERCEL_ENV_CHECKLIST.md for deploy setup.

# App URL for auth redirects (signup email, OAuth, password reset).
# Local: http://localhost:3000 — Production (Vercel): https://cleaneats.fit
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Settings → API → anon public). Safe for browser; RLS protects data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Anthropic API key for /api/generate (server-only — do NOT prefix with NEXT_PUBLIC_)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Set to 1 or true to skip Anthropic and return mock plan fixtures (local dev / CI only)
MOCK_GENERATION=

# Mock fixture id when MOCK_GENERATION is enabled (e.g. zm_male_fatloss, us_female_muscle)
MOCK_FIXTURE_ID=

# Supabase service role key (Settings → API → service_role). Server/cron only — never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# NODE_ENV is set automatically by Next.js (development | production | test). Do not set manually unless needed.

# Cron route auth (Vercel sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=your-cron-secret

# Unsplash — meal card images (browser; Unsplash API access key)
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=
